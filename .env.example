DATABASE_URL="mysql://root:your_password@localhost:3306/tesk_backend"
REDIS_URL="redis://localhost:6379"
PORT=4000

# 管理后台账号密码与接口 Token
ADMIN_USER="admin"
ADMIN_PASS="admin123"
ADMIN_API_KEY="admin-secret-key-change-in-production"

# 上游并发自动排队配置 (JSON 格式)
# 示例: [{"platform":"runninghub","key":"rh_key_1","concurrency":3},{"platform":"runninghub","key":"rh_key_2","concurrency":2}]
UPSTREAM_CONFIG='[]'

# 上游 API Key
RUNNINGHUB_API_KEY=""
GPTIMAGE2_API_KEY=""
GEMINI_API_KEY=""

# S3 对象存储
S3_ENDPOINT=""
S3_REGION="auto"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET=""

# 性能调优 (一般无需修改)
# WORKER_CONCURRENCY=20       # Model Worker 每进程并行任务数
# APP_WORKER_CONCURRENCY=8    # App Worker 每进程并行任务数 (= 上游 Key 并发总量)
# PROCESS_TYPE=all             # 进程模式: all|api|worker|timeout
# DATABASE_POOL_LIMIT=30       # Prisma 数据库连接池大小
